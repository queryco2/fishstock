{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FishStock",
  "version": "0.1.0",
  "identifier": "com.fishstock.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FishStock",
        "width": 390,
        "height": 540,
        "minWidth": 340,
        "minHeight": 460
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": []
  }
}
